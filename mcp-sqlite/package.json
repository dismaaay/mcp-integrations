{
  "name": "mcp-sqlite-safe",
  "version": "1.0.0",
  "description": "Read-only MCP server for SQLite databases — let Claude query your data safely, with a SELECT-only guard.",
  "type": "module",
  "bin": {
    "mcp-sqlite-safe": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "seed": "node --experimental-sqlite --import tsx src/seed.ts",
    "start": "node --experimental-sqlite dist/index.js",
    "dev": "node --experimental-sqlite --import tsx src/index.ts",
    "test": "node --experimental-sqlite --import tsx --test src/*.test.ts"
  },
  "keywords": ["mcp", "model-context-protocol", "claude", "sqlite", "database", "read-only"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
