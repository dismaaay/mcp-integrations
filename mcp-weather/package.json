{
  "name": "mcp-weather",
  "version": "1.0.0",
  "description": "MCP server that gives Claude live weather & forecasts via the free Open-Meteo API (no API key required).",
  "type": "module",
  "bin": {
    "mcp-weather": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/*.test.ts",
    "dev": "node --import tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "weather",
    "open-meteo"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
